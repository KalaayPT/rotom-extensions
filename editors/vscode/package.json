{
  "name": "rotom-vscode",
  "displayName": "Rotoscript Support",
  "description": "Language support for the Rotom scripting language",
  "version": "0.1.0",
  "publisher": "Kalaay",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KalaayPT/rotom-extensions"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:rotom",
    "workspaceContains:**/rotom.toml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "rotom",
        "aliases": [
          "Rotom",
          "rotom"
        ],
        "extensions": [
          ".rotom"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "rotom",
        "scopeName": "source.rotom",
        "path": "./syntaxes/rotom.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "rotom.showReferences",
        "title": "Rotom: Show References"
      }
    ],
    "configuration": {
      "title": "Rotom",
      "properties": {
        "rotom.lsp.path": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Path to the rotom-lsp binary. If unset, searches extension bin/, workspace target/ builds, then $PATH."
        }
      }
    },
    "configurationDefaults": {
      "[rotom]": {
        "editor.codeLens": true
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.2",
    "ovsx": "^1.0.0",
    "typescript": "^5.3.0"
  }
}
