{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Rotom",
  "scopeName": "source.rotom",
  "fileTypes": [".rotom"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#preprocessor" },
    { "include": "#keywords" },
    { "include": "#control" },
    { "include": "#operators" },
    { "include": "#numbers" },
    { "include": "#strings" },
    { "include": "#functions" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.rotom", "match": "//.*$" },
        { "name": "comment.block.rotom", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "preprocessor": {
      "patterns": [
        {
          "name": "meta.preprocessor.rotom",
          "match": "^\\s*(#include|#define)\\b.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.rotom",
          "match": "\\b(script|action|alias|as|break|Jump|GoTo|End|Return|EndMovement)\\b"
        }
      ]
    },
    "control": {
      "patterns": [
        {
          "name": "keyword.control.conditional.rotom",
          "match": "\\b(if|then|else|endif|match|with|case|endmatch)\\b"
        },
        {
          "name": "keyword.control.repeat.rotom",
          "match": "\\b(while|do|endwhile)\\b"
        },
        {
          "name": "constant.language.boolean.rotom",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.rotom",
          "match": "(==|!=|<=|>=|<|>|&&|\\|\\||\\band\\b|\\bor\\b|\\bnot\\b|!|\\+|\\-|\\*)"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.rotom",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        { "name": "constant.numeric.decimal.rotom", "match": "\\b-?[0-9]+\\b" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.rotom",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.rotom", "match": "\\\\\"" }
          ]
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.type.rotom",
          "match": "(?<=^\\s*script\\s+)([A-Za-z_][A-Za-z0-9_]*)",
          "comment": "script name"
        },
        {
          "name": "entity.name.type.rotom",
          "match": "(?<=^\\s*action\\s+)([A-Za-z_][A-Za-z0-9_]*)",
          "comment": "action name"
        },
        {
          "match": "^\\s*(?!(?:if|then|else|endif|match|with|case|endmatch|while|do|endwhile|alias|as|break|Jump|GoTo|End|Return|EndMovement|script|action)\\b)([A-Za-z_][A-Za-z0-9_]*)(?=\\s*:)",
          "captures": {
            "1": { "name": "entity.name.type.rotom" }
          },
          "comment": "top-level label definitions"
        },
        {
          "name": "entity.name.type.rotom",
          "match": "(?<=^\\s*)(\\.[A-Za-z_][A-Za-z0-9_]*)(?=\\s*:)",
          "comment": "local label definitions"
        },
        {
          "name": "entity.name.function.rotom",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "comment": "call-style commands"
        },
        {
          "match": "^\\s*(?!(?:if|then|else|endif|match|with|case|endmatch|while|do|endwhile|alias|as|break|Jump|GoTo|End|Return|EndMovement|script|action)\\b)([A-Za-z_][A-Za-z0-9_]*)(?=\\s+(?:0[xX][0-9a-fA-F]+|-?[0-9]+|true|false|\"|[A-Za-z_.]))",
          "captures": {
            "1": { "name": "entity.name.function.rotom" }
          },
          "comment": "assembly-style commands with arguments"
        },
        {
          "match": "^\\s*(?!(?:if|then|else|endif|match|with|case|endmatch|while|do|endwhile|alias|as|break|Jump|GoTo|End|Return|EndMovement|script|action)\\b)([A-Za-z_][A-Za-z0-9_]*)\\s*$",
          "captures": {
            "1": { "name": "entity.name.function.rotom" }
          },
          "comment": "assembly-style commands with no arguments"
        }
      ]
    }
  }
}
